# 仅对 ${API_UPSTREAM} 做 envsubst，Nginx 内建变量放在 nginx-snippets/ 的静态 include 中
server {
    listen 80;
    server_name localhost;
    root /usr/share/nginx/html;
    index index.html;

    include /etc/nginx/snippets/spa-tryfiles.conf;

    location /api/ {
        proxy_pass http://${API_UPSTREAM}/api/;
        include /etc/nginx/snippets/api-proxy-common.conf;
        proxy_connect_timeout 60s;
        proxy_read_timeout 60s;
    }
}
