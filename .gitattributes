# Explicitly declare files that should have CRLF line endings on checkout
*.bat text eol=crlf
*.ps1 text eol=crlf
*.sh text eol=lf
*.py text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.html text eol=lf
*.css text eol=lf

# Binary files - no conversion
*.ico binary
*.png binary
*.jpg binary
*.gif binary
*.jpeg binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.mp3 binary
*.mp4 binary
*.wav binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.7z binary
