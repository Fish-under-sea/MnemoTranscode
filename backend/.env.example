# 复制为 .env 后按需填写（勿把真实密钥提交到 Git）

# --- LLM（聊天记录 AI 导入、对话、构图等必填其一）---
# OpenAI 或兼容 OpenAI Chat Completions 的网关
LLM_API_KEY=sk-your-key-here
# 若你习惯只配官方变量名，也可二选一（与 LLM_API_KEY 等价）：
# OPENAI_API_KEY=sk-your-key-here

LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# 本地数据库（Docker Compose 会通过环境变量覆盖为 postgres 服务）
# DATABASE_URL=postgresql+asyncpg://mtc:mtc_password@localhost:5432/mtc_db
